<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>{{TITLE}} — Hormozi Agent</title>
<style>
  :root {
    --bg: #0a0a0f;
    --panel: #0d0d18;
    --border: #1a1a2e;
    --text: #e8e8f0;
    --muted: #8a8a9a;
    --green: #00ff88;
    --amber: #ffaa00;
    --red: #ff4444;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Courier New', monospace;
    line-height: 1.6;
    padding: 40px 20px;
    min-height: 100vh;
  }
  .wrap { max-width: 920px; margin: 0 auto; }
  .header {
    border: 1px solid var(--border);
    background: var(--panel);
    padding: 24px 28px;
    margin-bottom: 32px;
    border-radius: 4px;
  }
  .header .eyebrow {
    color: var(--green);
    font-size: 12px;
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 8px;
  }
  .header h1 {
    font-size: 28px;
    font-weight: bold;
    color: var(--text);
    margin-bottom: 8px;
  }
  .header .meta {
    color: var(--muted);
    font-size: 13px;
  }
  .section {
    border: 1px solid var(--border);
    background: var(--panel);
    padding: 24px 28px;
    margin-bottom: 24px;
    border-radius: 4px;
  }
  .section-title {
    color: var(--amber);
    font-size: 13px;
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 16px;
    border-bottom: 1px solid var(--border);
    padding-bottom: 12px;
  }
  .hook {
    border-left: 3px solid var(--green);
    padding: 12px 18px;
    margin-bottom: 14px;
    background: rgba(0, 255, 136, 0.04);
    font-size: 17px;
  }
  .hook-label {
    color: var(--green);
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 6px;
  }
  .promise {
    color: var(--text);
    font-size: 16px;
    padding: 8px 0;
  }
  ol.outline { padding-left: 22px; }
  ol.outline li {
    margin-bottom: 18px;
    padding-left: 8px;
  }
  ol.outline li strong {
    color: var(--green);
    display: block;
    margin-bottom: 4px;
  }
  ol.outline li .body {
    color: var(--text);
  }
  ol.outline li .broll {
    color: var(--amber);
    font-size: 13px;
    margin-top: 6px;
    padding: 6px 10px;
    background: rgba(255, 170, 0, 0.06);
    border-left: 2px solid var(--amber);
  }
  .cta {
    border-left: 3px solid var(--amber);
    padding: 12px 18px;
    margin-top: 8px;
    font-size: 16px;
    background: rgba(255, 170, 0, 0.04);
  }
  .footer {
    text-align: center;
    color: var(--muted);
    font-size: 12px;
    margin-top: 40px;
    padding-top: 24px;
    border-top: 1px solid var(--border);
  }
  .framework-tag {
    display: inline-block;
    color: var(--green);
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 3px 8px;
    border: 1px solid var(--green);
    border-radius: 3px;
    margin-right: 6px;
    margin-bottom: 4px;
  }
</style>
</head>
<body>
<div class="wrap">

  <div class="header">
    <div class="eyebrow">▓ HORMOZI AGENT — SCRIPT</div>
    <h1>{{TITLE}}</h1>
    <div class="meta">{{DATE}} • Framework: <span style="color: var(--green)">{{PRIMARY_FRAMEWORK}}</span></div>
  </div>

  <div class="section">
    <div class="section-title">▓ HOOKS — pick one, A/B the others</div>
    <div class="hook">
      <div class="hook-label">Hook A — Problem-led</div>
      {{HOOK_A}}
    </div>
    <div class="hook">
      <div class="hook-label">Hook B — Outcome-led</div>
      {{HOOK_B}}
    </div>
    <div class="hook">
      <div class="hook-label">Hook C — Curiosity-led</div>
      {{HOOK_C}}
    </div>
  </div>

  <div class="section">
    <div class="section-title">▓ PROMISE</div>
    <div class="promise">{{PROMISE}}</div>
  </div>

  <div class="section">
    <div class="section-title">▓ OUTLINE</div>
    <ol class="outline">
      {{OUTLINE_ITEMS}}
    </ol>
  </div>

  <div class="section">
    <div class="section-title">▓ CTA</div>
    <div class="cta">{{CTA}}</div>
  </div>

  <div class="section">
    <div class="section-title">▓ FRAMEWORKS USED</div>
    <div>
      {{FRAMEWORK_TAGS}}
    </div>
  </div>

  <div class="footer">
    Generated by Hormozi Agent • run /hormozi generate to make another
  </div>

</div>
</body>
</html>
